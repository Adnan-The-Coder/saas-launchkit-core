{
  "name": "@repo/http",
  "sourceRoot": "packages/http/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --build tsconfig.json",
        "cwd": "packages/http"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --build tsconfig.json --emitDeclarationOnly",
        "cwd": "packages/http"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx eslint src/",
        "cwd": "packages/http"
      }
    }
  }
}
