# Server API URL (required)
# The URL of your Hono API server
NEXT_PUBLIC_SERVER_URL=http://localhost:8787

# App name (optional)
# Used for branding in UI and metadata. Defaults to "YourApp".
NEXT_PUBLIC_APP_NAME=YourApp

# Site URL (optional)
# Used for metadata and SEO
NEXT_PUBLIC_SITE_URL=http://localhost:3000
